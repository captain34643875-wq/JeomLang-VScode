{
  "name": "jeom-vscode-runner",
  "displayName": "JEOM VS Code Runner",
  "description": "Unofficial VS Code runner and language helpers for JEOM .jeom files.",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "keywords": [
    "jeom",
    "jeomlang",
    "esolang",
    "unicode",
    "vscode"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:jeom",
    "onCommand:jeom.runFile",
    "onCommand:jeom.checkFile"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jeom",
        "aliases": [
          "JEOM",
          "jeom"
        ],
        "extensions": [
          ".jeom"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/jeom-icon.svg",
          "dark": "./assets/jeom-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "jeom",
        "scopeName": "source.jeom",
        "path": "./syntaxes/jeom.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "jeom",
        "path": "./snippets/jeom.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "jeom.runFile",
        "title": "Run JEOM File",
        "category": "JEOM",
        "icon": "$(play)"
      },
      {
        "command": "jeom.checkFile",
        "title": "Check JEOM File",
        "category": "JEOM",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jeom.runFile",
          "when": "resourceLangId == jeom",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "jeom.runFile",
          "when": "resourceLangId == jeom",
          "group": "navigation@1"
        },
        {
          "command": "jeom.checkFile",
          "when": "resourceLangId == jeom",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "jeom.runFile",
          "when": "resourceExtname == .jeom",
          "group": "navigation@1"
        },
        {
          "command": "jeom.checkFile",
          "when": "resourceExtname == .jeom",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "jeom.runFile",
          "when": "resourceLangId == jeom"
        },
        {
          "command": "jeom.checkFile",
          "when": "resourceLangId == jeom"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jeom.runFile",
        "key": "ctrl+f5",
        "when": "editorTextFocus && resourceLangId == jeom"
      }
    ],
    "configuration": {
      "title": "JEOM",
      "properties": {
        "jeom.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to jeom_cli.js. Supports ${workspaceFolder}. If empty, the extension uses its bundled jeom_cli.js."
        },
        "jeom.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show Run and Check CodeLens actions at the top of JEOM files."
        }
      }
    }
  }
}
